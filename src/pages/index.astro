---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfileHeader from '../components/ProfileHeader.astro';
import PillarCard from '../components/PillarCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import TechBadges from '../components/TechBadges.astro';
---

<BaseLayout title="Magnus Hinzke — IT-Infrastruktur, Digitalisierung & Geschäftsführung">
  <ProfileHeader />

  <!-- Drei Säulen -->
  <section class="section">
    <h2 class="section-title">Was ich mache</h2>
    <div class="pillars-grid">
      <PillarCard
        title="IT-Infrastruktur & Systemadministration"
        icon=">"
        pitch="Seit dem Amiga 2000 an der Kommandozeile. Kernkompetenz seit 30+ Jahren. Server aufsetzen, Netzwerke konfigurieren, Dienste deployen — im Schlaf."
        accentColor="var(--ctp-teal)"
        tags={['Linux', 'Docker', 'Proxmox VE', 'Hetzner Cloud', 'Dokploy', 'Traefik', 'Cloudflare', 'SSH', 'Bash', 'Uptime Kuma', 'Matomo', 'Metabase']}
      >
        <ul>
          <li><strong>Server & Virtualisierung</strong> — Proxmox VE, Hetzner Cloud, Dokploy, Docker Compose</li>
          <li><strong>Netzwerk & DNS</strong> — Cloudflare (DNS, CDN, WAF, Zero Trust), UniFi, Technitium DNS</li>
          <li><strong>Linux</strong> — SuSE, RedHat, Ubuntu/Debian, Bash-Scripting</li>
          <li><strong>Monitoring</strong> — Uptime Kuma, Matomo, SerpBear, Metabase</li>
          <li><strong>Self-Hosted</strong> — n8n, FreeScout, Listmonk, Paperless-ngx, Roundcube, Twenty CRM, POS-Displays</li>
        </ul>
      </PillarCard>

      <PillarCard
        title="Digitalisierung & Automatisierung"
        icon=">"
        pitch="Vom Auftrag bis zur Lieferung durchautomatisiert. Produktive n8n-Workflows, Shopware-Shop mit Custom Plugins, ERP-Integration über mehrere Systeme."
        accentColor="var(--ctp-sky)"
        tags={['n8n', 'Shopware', 'Obility ERP', 'ReFast', 'LexOffice', 'DATEV', 'GoCardless', 'Stripe', 'OpenAI API', 'Claude API', 'Enfocus Switch', 'callas pdfToolbox']}
      >
        <ul>
          <li><strong>Workflow-Automation</strong> — Debitoren-Management, Newsletter-Pipeline, Notification Hub, Vertriebsautomation</li>
          <li><strong>E-Commerce</strong> — Shopware mit Custom Plugins, Store API, SEO-Automation</li>
          <li><strong>ERP-Integration</strong> — Obility, ReFast, LexOffice, DATEV</li>
          <li><strong>Druckvorstufe</strong> — Enfocus Switch, callas pdfToolbox, Farbmanagement, PDF-Automation</li>
          <li><strong>Change Management</strong> — Switch-zu-n8n Migration, Microsoft-365-zu-All-Inkl, WordPress-zu-Astro</li>
        </ul>
      </PillarCard>

      <PillarCard
        title="Geschäftsführer-Perspektive"
        icon=">"
        pitch="Einen Betrieb führen heißt: Alles gleichzeitig. Finanzen, Personal, Vertrieb, Produktion — und nebenbei die IT modernisieren."
        accentColor="var(--ctp-peach)"
        tags={['BWA', 'Liquiditätsplanung', 'DATEV', 'E-Commerce', 'Sponsoring', 'SEO', 'B2B-Vertrieb']}
      >
        <ul>
          <li><strong>Unternehmensführung</strong> — Volker Hinzke GmbH, durchautomatisiert — was andere mit deutlich mehr Leuten machen</li>
          <li><strong>Finanzen</strong> — BWA-Analyse, Liquiditätsplanung (Tidely), DATEV-Abstimmung</li>
          <li><strong>Vertrieb & Marketing</strong> — E-Commerce, Sponsoring, Newsletter, SEO</li>
          <li><strong>Auftragsabwicklung</strong> — Anfrage bis Archivierung durchautomatisiert</li>
        </ul>
      </PillarCard>
    </div>
  </section>

  <!-- Projekte -->
  <section class="section">
    <h2 class="section-title">Projekte & Ventures</h2>
    <div class="projects-grid">
      <ProjectCard
        title="Flowboost"
        description="AI Content Agents. Automatisierte Content-Erstellung mit KI."
        url="https://www.flowboost.ai/"
        accentColor="var(--ctp-peach)"
        features={['AI Content Agents', 'Automatisierte Erstellung', 'Mitarbeit']}
      />
      <ProjectCard
        title="Hinzke Digital"
        description="Digitale Produkte und KI-Automatisierung für den Mittelstand. Weniger Handarbeit, mehr Ergebnis."
        url="https://hinzke.digital"
        accentColor="var(--ctp-sky)"
        features={['KI-Module & Automatisierung', 'IT & Prozessoptimierung', 'Webseiten & Portale', 'Kein Vendor Lock-in']}
      />
      <ProjectCard
        title="Hanse Graphics"
        description="Textildruck und Veredelung. 2022 akquiriert und in die Volker Hinzke GmbH integriert."
        accentColor="var(--ctp-teal)"
        features={['Textildruck', 'Veredelung', 'B2B & Vereine', 'Teil der Hinzke-Gruppe']}
      />
      <ProjectCard
        title="Volker Hinzke GmbH"
        description="Druckerei seit 1982. Lean und durchdigitalisiert — variabler Datendruck, Reprographie, Medienproduktion, Textildruck und Werbetechnik."
        url="https://hinzke.de"
        accentColor="var(--ctp-blue)"
        features={['E-Commerce mit Shopware', 'Textildruck & Veredelung integriert', 'Automatisiert statt aufgebläht']}
      />
      <ProjectCard
        title="RC-Park Lübeck e.V."
        description="2009 gegründet. Modellbau-Verein für ferngesteuerte Autos, Boote und Flugzeuge."
        url="https://rc-park-hl.de/"
        accentColor="var(--ctp-green)"
        features={['RC-Modellbau', 'Vereinsgründer', 'Community']}
      />
      <ProjectCard
        title="Galactic Tales"
        description="MMO-Browsergame mit persistentem Universum. Händler, Piraten und Kopfgeldjäger im Weltraum."
        url="https://galactic-tales.eu"
        accentColor="var(--ctp-lavender)"
        features={['Browsergame', 'Persistentes Universum', 'Community']}
      />
    </div>
  </section>

  <!-- Tech-Stack -->
  <TechBadges />

</BaseLayout>

<style>
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--spacing-lg);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-md);
  }

  @media (max-width: 768px) {
    .pillars-grid {
      grid-template-columns: 1fr;
    }

    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
