---
import TypeWriter from './TypeWriter.astro';
import SocialLinks from './SocialLinks.astro';
---

<section class="profile">
  <div class="profile-content">
    <img
      src="/images/magnus-hinzke.webp"
      alt="Magnus Hinzke"
      class="profile-img"
      width="160"
      height="160"
    />
    <div class="profile-text">
      <h1>Magnus Hinzke</h1>
      <TypeWriter
        words={['IT-Infrastruktur', 'Digitalisierung', 'Geschäftsführung', 'Automatisierung', 'Linux seit 25+ Jahren']}
      />
      <p class="profile-pitch">
        Unternehmer aus Lübeck. 40+ Jahre Druckbranche, 25+ Jahre Linux,
        15+ Jahre Geschäftsführung. Die seltene Kombination: Admin + CEO.
      </p>
      <SocialLinks />
    </div>
  </div>
</section>

<style>
  .profile {
    padding: var(--spacing-2xl) 0 var(--spacing-xl);
  }

  .profile-content {
    display: flex;
    align-items: center;
    gap: var(--spacing-xl);
  }

  .profile-img {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--color-border);
    flex-shrink: 0;
  }

  .profile-text h1 {
    font-size: 2.75rem;
    margin-bottom: var(--spacing-xs);
  }

  .profile-pitch {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    max-width: 560px;
    margin-top: var(--spacing-md);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .profile-content {
      flex-direction: column;
      text-align: center;
      gap: var(--spacing-lg);
    }

    .profile-text h1 {
      font-size: 2rem;
    }

    .profile-img {
      width: 120px;
      height: 120px;
    }

    .profile-pitch {
      font-size: 1rem;
    }
  }
</style>
