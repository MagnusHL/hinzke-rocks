---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Start' },
  { href: '/ueber-mich', label: 'Über mich' },
];
---

<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <img src="/images/logo-hinzke-rocks.webp" alt="hinzke.rocks" class="nav-logo-img" />
    </a>
    <div class="nav-links">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={['nav-link', { active: currentPath === link.href || currentPath === link.href + '/' }]}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<style>
  .nav {
    z-index: 100;
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--spacing-md) var(--spacing-lg);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-lg);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .nav-logo-img {
    height: 40px;
    width: auto;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    font-weight: 500;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .nav-inner {
      padding: var(--spacing-sm) var(--spacing-md);
    }

    .nav-logo-img {
      height: 32px;
    }

    .nav-links {
      gap: var(--spacing-md);
    }
  }
</style>
