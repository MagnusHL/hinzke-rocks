---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Impressum — Magnus Hinzke" description="Impressum gemäß § 5 DDG">
  <section class="section legal">
    <h1>Impressum</h1>
    <p class="legal-ref">Angaben gemäß § 5 DDG</p>

    <h2>Verantwortlich</h2>
    <p>
      Magnus Hinzke<br />
      Kücknitzer Hauptstraße 26<br />
      23569 Lübeck
    </p>

    <h2>Kontakt</h2>
    <p>
      E-Mail: <a href="mailto:magnus@hinzke.de">magnus@hinzke.de</a><br />
      Telefon: +49 451 30 77 30
    </p>

    <h2>Berufliche Tätigkeit</h2>
    <p>
      Geschäftsführer der Volker Hinzke GmbH<br />
      Kücknitzer Hauptstraße 26, 23569 Lübeck<br />
      <a href="https://hinzke.de" target="_blank" rel="noopener noreferrer">hinzke.de</a>
    </p>
  </section>
</BaseLayout>

<style>
  .legal {
    max-width: 640px;
  }

  .legal h2 {
    font-size: 1.1rem;
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-sm);
  }

  .legal p {
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .legal-ref {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: var(--spacing-sm);
  }
</style>
