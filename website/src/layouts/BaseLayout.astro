---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Magnus Hinzke — IT-Infrastruktur, Digitalisierung & Geschäftsführung. Unternehmer aus Lübeck.',
  ogImage = '/images/magnus-hinzke.webp',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content="de_DE" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="apple-touch-icon" href="/favicon-192.png" />

    <!-- Fonts -->
    <link rel="preload" href="/fonts/jetbrains-mono-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-latin-400.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Person Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Magnus Hinzke",
      "jobTitle": "Geschäftsführer & IT-Infrastruktur",
      "url": "https://hinzke.rocks",
      "image": new URL(ogImage, Astro.site).toString(),
      "sameAs": [
        "https://www.linkedin.com/in/mhinzke/",
        "https://github.com/MagnusHL"
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Lübeck",
        "addressCountry": "DE"
      },
      "worksFor": {
        "@type": "Organization",
        "name": "Volker Hinzke GmbH",
        "url": "https://hinzke.de"
      }
    })} />
    <!-- Matomo -->
    <script is:inline>
      var _paq = window._paq = window._paq || [];
      _paq.push(['trackPageView']);
      _paq.push(['enableLinkTracking']);
      (function() {
        var u="https://analytics.hinzke.de/";
        _paq.push(['setTrackerUrl', u+'matomo.php']);
        _paq.push(['setSiteId', '5']);
        var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
        g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
      })();
    </script>
  </head>
  <body>
    <Navigation />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  /* === Fonts === */
  @font-face {
    font-family: 'JetBrains Mono';
    font-style: normal;
    font-display: swap;
    font-weight: 100 900;
    src: url('/fonts/jetbrains-mono-latin-wght-normal.woff2') format('woff2');
  }

  @font-face {
    font-family: 'Inter';
    font-style: normal;
    font-display: swap;
    font-weight: 400;
    src: url('/fonts/inter-latin-400.woff2') format('woff2');
  }

  @font-face {
    font-family: 'Inter';
    font-style: normal;
    font-display: swap;
    font-weight: 500;
    src: url('/fonts/inter-latin-500.woff2') format('woff2');
  }

  @font-face {
    font-family: 'Inter';
    font-style: normal;
    font-display: swap;
    font-weight: 600;
    src: url('/fonts/inter-latin-600.woff2') format('woff2');
  }

  @font-face {
    font-family: 'Inter';
    font-style: normal;
    font-display: swap;
    font-weight: 700;
    src: url('/fonts/inter-latin-700.woff2') format('woff2');
  }

  /* === Catppuccin Latte === */
  :root {
    --ctp-rosewater: #dc8a78;
    --ctp-flamingo: #dd7878;
    --ctp-pink: #ea76cb;
    --ctp-mauve: #8839ef;
    --ctp-red: #d20f39;
    --ctp-maroon: #e64553;
    --ctp-peach: #fe640b;
    --ctp-yellow: #df8e1d;
    --ctp-green: #40a02b;
    --ctp-teal: #179299;
    --ctp-sky: #04a5e5;
    --ctp-sapphire: #209fb5;
    --ctp-blue: #1e66f5;
    --ctp-lavender: #7287fd;
    --ctp-text: #4c4f69;
    --ctp-subtext1: #5c5f77;
    --ctp-subtext0: #6c6f85;
    --ctp-overlay2: #7c7f93;
    --ctp-overlay1: #8c8fa1;
    --ctp-overlay0: #9ca0b0;
    --ctp-surface2: #acb0be;
    --ctp-surface1: #bcc0cc;
    --ctp-surface0: #ccd0da;
    --ctp-base: #eff1f5;
    --ctp-mantle: #e6e9ef;
    --ctp-crust: #dce0e8;

    --color-bg: var(--ctp-base);
    --color-bg-subtle: var(--ctp-mantle);
    --color-bg-secondary: var(--ctp-crust);
    --color-text: var(--ctp-text);
    --color-text-secondary: var(--ctp-subtext0);
    --color-text-muted: var(--ctp-overlay1);
    --color-border: var(--ctp-surface0);
    --color-accent: var(--ctp-sky);
    --color-accent-hover: var(--ctp-sapphire);

    --font-mono: 'JetBrains Mono', ui-monospace, monospace;
    --font-sans: 'Inter', system-ui, -apple-system, sans-serif;

    --max-width: 1100px;
    --spacing-xs: 0.25rem;
    --spacing-sm: 0.5rem;
    --spacing-md: 1rem;
    --spacing-lg: 2rem;
    --spacing-xl: 4rem;
    --spacing-2xl: 6rem;

    --radius-sm: 6px;
    --radius-md: 10px;
    --radius-lg: 16px;
  }

  /* === Reset === */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    -webkit-text-size-adjust: 100%;
  }

  body {
    font-family: var(--font-sans);
    font-weight: 400;
    line-height: 1.7;
    color: var(--color-text);
    background-color: var(--color-bg);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  main {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--spacing-lg);
  }

  h1, h2, h3, h4 {
    font-family: var(--font-mono);
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-text);
  }

  h1 { font-size: 2.5rem; }
  h2 { font-size: 1.75rem; }
  h3 { font-size: 1.25rem; }

  a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s;
  }

  a:hover {
    color: var(--color-accent-hover);
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  /* === Sections === */
  .section {
    padding: var(--spacing-2xl) 0;
  }

  .section-title {
    margin-bottom: var(--spacing-lg);
    font-size: 1.75rem;
  }

  /* === Responsive === */
  @media (max-width: 768px) {
    h1 { font-size: 1.75rem; }
    h2 { font-size: 1.35rem; }
    h3 { font-size: 1.1rem; }

    main {
      padding: 0 var(--spacing-md);
    }

    .section {
      padding: var(--spacing-xl) 0;
    }
  }
</style>
